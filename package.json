{
  "name": "portfolio",
  "packageManager": "bun@1.3.10",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "prepare": "if command -v git >/dev/null 2>&1 && command -v lefthook >/dev/null 2>&1 && [ -d .git ]; then lefthook install; else echo 'lefthook: skip'; fi",
    "update": "bun update -i",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "bun x ultracite check",
    "format": "bun x ultracite fix",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "check": "bun run lint && bun run typecheck && bun run test:unit && bun run build"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.0",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/outfit": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@react-pdf/renderer": "^4.3.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@biomejs/biome": "2.4.6",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "lefthook": "^2.1.4",
    "typescript": "~5.9.3",
    "ultracite": "7.3.0",
    "vite": "7.3.1",
    "vitest": "^4.1.0"
  }
}
