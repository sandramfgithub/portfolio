---
import {
  getEntryDetailPageViewModel,
  listEntryRouteParams,
} from '@/application/portfolio/queries';
import type { Lang } from '@/i18n/translations';
import EntryDetailTemplate from '@/templates/entry-detail.astro';

export async function getStaticPaths() {
  const routes = await listEntryRouteParams('public-project');

  return routes.map((route) => ({
    params: {
      lang: route.lang,
      slug: route.slug,
    },
    props: route,
  }));
}

const { lang, slug } = Astro.props as { lang: Lang; slug: string };
const page = await getEntryDetailPageViewModel(lang, 'public-project', slug);
---

<EntryDetailTemplate lang={lang} page={page} />
