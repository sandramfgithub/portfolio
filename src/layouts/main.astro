---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { getLayoutViewModel } from '@/application/portfolio/queries';
import AnalyticsScript from '@/components/layout/analytics-script.astro';
import { MorphNav } from '@/components/layout/morph-nav';
import SiteFooter from '@/components/layout/site-footer.astro';
import type { Lang } from '@/i18n/translations';
import { getAlternateLang, getLocalizedPath } from '@/i18n/utils';

type Props = {
  description?: string;
  hideFooter?: boolean;
  hideNavigation?: boolean;
  lang?: Lang;
  mainClassName?: string;
  noindex?: boolean;
  title?: string;
};

const { lang = 'es' } = Astro.props;

const defaultTitles: Record<Lang, string> = {
  es: 'Sandra Martínez Fernández | Desarrolladora de Software',
  en: 'Sandra Martínez Fernández | Software Developer',
};

const defaultDescriptions: Record<Lang, string> = {
  es: 'Portfolio de proyectos, librerías y documentación técnica.',
  en: 'Portfolio of projects, libraries, and technical documentation.',
};

const {
  title = defaultTitles[lang],
  description = defaultDescriptions[lang],
  hideFooter = false,
  hideNavigation = false,
  mainClassName = 'space-y-8 pb-10',
  noindex = false,
} = Astro.props;
const layout = hideNavigation ? null : await getLayoutViewModel(lang);

const altLang = getAlternateLang(lang);
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const altPath = getLocalizedPath(pathname, altLang);
const ogLocale = lang === 'es' ? 'es_ES' : 'en_US';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <meta name="description" content={description}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:locale" content={ogLocale}>
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    {noindex && <meta content="noindex, nofollow" name="robots" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="alternate" hreflang={altLang} href={altPath}>
    <link rel="alternate" hreflang={lang} href={pathname}>
    <title>{title}</title>
    <ClientRouter />
    <AnalyticsScript />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        if (stored === 'light') {
          return;
        }
        document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-primary-foreground"
    >
      {lang === 'en' ? 'Skip to content' : 'Saltar al contenido'}
    </a>
    {layout && (
      <MorphNav
        lang={lang}
        client:load
        navigation={layout.navigation}
        pathname={pathname}
        transition:persist
        socialLinks={layout.socialLinks}
      />
    )}
    <div
      class={`page-shell flex flex-1 flex-col ${hideNavigation ? '' : 'pt-10'}`}
    >
      <main class={`flex-1 ${mainClassName}`} id="main"><slot /></main>
      {!hideFooter && <SiteFooter lang={lang} />}
    </div>
    <script>
      document.addEventListener('astro:after-swap', () => {
        const stored = localStorage.getItem('theme');
        document.documentElement.classList.toggle('dark', stored !== 'light');
        document
          .querySelector('footer')
          ?.style.setProperty('animation', 'none');
      });
    </script>
  </body>
</html>
