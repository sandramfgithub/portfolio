---
import { getCvViewModel } from '@/application/cv/queries';
import { getAboutPageViewModel } from '@/application/portfolio/queries';
import AboutExperienceList from '@/components/about/about-experience-list.astro';
import AboutHero from '@/components/about/about-hero.astro';
import { AboutRichText } from '@/components/about/about-rich-text';
import { CvDownload } from '@/components/cv/cv-download';
import { StackList } from '@/components/portfolio/skills/stack-list';
import type { Lang } from '@/i18n/translations';
import { getTranslations } from '@/i18n/utils';
import Layout from '@/layouts/main.astro';

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = getTranslations(lang);
const [page, cv] = await Promise.all([
  getAboutPageViewModel(lang),
  getCvViewModel(lang),
]);
---

<Layout description={page.description} lang={lang} title={page.title}>
  <AboutHero hero={page.hero}>
    <AboutRichText
      className="text-sm leading-6 text-muted-foreground sm:text-base sm:leading-7"
      client:load
      paragraphs={page.professional}
      popovers={page.popovers}
    />
    <div class="mt-6"><CvDownload cv={cv} lang={lang} client:load /></div>
  </AboutHero>

  <section class="py-2">
    <AboutRichText
      className="text-sm leading-6 text-muted-foreground sm:text-base sm:leading-7"
      client:load
      paragraphs={page.personal}
      popovers={page.popovers}
    />
  </section>

  <AboutExperienceList
    experience={page.experience}
    heading={t.about.experience}
    lang={lang}
  />

  <!-- Skills -->
  <section class="space-y-3">
    <h2 class="font-serif text-xl font-semibold tracking-tight">
      {t.about.skills}
    </h2>
    <StackList
      lang={lang}
      location="about"
      skills={page.skills}
      client:visible
    />
  </section>
</Layout>
