---
import { getHomePageViewModel } from '@/application/portfolio/queries';
import { Terminal } from '@/components/terminal/terminal';
import type { Lang } from '@/i18n/translations';
import Layout from '@/layouts/main.astro';

type Props = { lang: Lang };
const { lang } = Astro.props;
const page = await getHomePageViewModel(lang);
---

<Layout description={page.description} lang={lang} title={page.title}>
  <section class="py-2 sm:py-4">
    {page.introParagraphs.map((paragraph) => (
      <p
        class="mx-auto max-w-2xl text-center text-muted-foreground text-sm leading-6 sm:text-base sm:leading-7"
      >
        {paragraph}
      </p>
    ))}
    <Terminal lang={lang} client:visible className="mt-6" />
  </section>
</Layout>
