---
import type { Lang } from '@/i18n/translations';
import { getLocalizedPath, getTranslations } from '@/i18n/utils';
import Layout from '@/layouts/main.astro';

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = getTranslations(lang);
const homeHref = getLocalizedPath('/', lang);
---

<Layout lang={lang} noindex={true}>
  <div class="py-16 text-center sm:py-20">
    <p class="eyebrow mb-4">{t.notFound.code}</p>
    <h1 class="font-serif text-2xl font-semibold tracking-tight sm:text-3xl">
      {t.notFound.heading}
    </h1>
    <p class="mt-3 text-sm leading-7 text-muted-foreground">
      {t.notFound.description}
    </p>
    <a
      href={homeHref}
      class="mt-8 inline-flex h-9 items-center rounded-lg bg-primary px-4 text-sm font-medium text-primary-foreground transition-all duration-150 hover:opacity-90 active:translate-y-px focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:outline-none"
    >
      {t.notFound.cta}
    </a>
  </div>
</Layout>
