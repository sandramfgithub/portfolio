---
import type { EntryDetailPageViewModel } from '@/application/portfolio/dto';
import { StackList } from '@/components/stack-list';
import type { Lang } from '@/i18n/translations';
import { getTranslations } from '@/i18n/utils';
import Layout from '@/layouts/main.astro';

type Props = {
  lang: Lang;
  page: EntryDetailPageViewModel;
};

const { lang, page } = Astro.props;
const t = getTranslations(lang);
const eyebrow =
  page.kind === 'public-project' ? t.entry.publicProject : t.entry.caseStudy;
const backLabel =
  page.kind === 'public-project'
    ? t.entry.backToProjects
    : t.entry.backToCaseStudies;
const bodyParagraphs =
  page.paragraphs.length > 0 ? page.paragraphs : [page.summary];
---

<Layout description={page.description} lang={lang} title={page.seoTitle}>
  <article class="space-y-8 py-2 sm:py-4">
    <div class="space-y-4">
      <a
        class="text-muted-foreground text-sm underline transition-colors hover:text-foreground"
        href={page.listingHref}
      >
        {backLabel}
      </a>
      <div class="space-y-3">
        <p class="eyebrow">{eyebrow}</p>
        <h1
          class="font-serif text-3xl font-semibold tracking-tight sm:text-4xl"
        >
          {page.title}
        </h1>
        <p
          class="max-w-2xl text-muted-foreground text-sm leading-7 sm:text-base"
        >
          {page.summary}
        </p>
      </div>
    </div>

    <section class="space-y-3">
      <h2 class="font-serif text-xl font-semibold tracking-tight">
        {t.entry.summary}
      </h2>
      <div
        class="space-y-3 text-muted-foreground text-sm leading-7 sm:text-base"
      >
        {bodyParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </section>

    {page.bullets.length > 0 && (
      <section class="space-y-3">
        <h2 class="font-semibold font-serif text-xl tracking-tight">
          {t.entry.highlights}
        </h2>
        <ul class="grid gap-2 text-muted-foreground text-sm leading-7 sm:text-base">
          {page.bullets.map((bullet) => (
            <li class="flex gap-3">
              <span class="mt-[0.6rem] h-1.5 w-1.5 shrink-0 rounded-full bg-foreground/30" />
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="space-y-3">
      <h2 class="font-serif text-xl font-semibold tracking-tight">
        {t.entry.stack}
      </h2>
      <StackList lang={lang} skills={page.skills} client:visible />
    </section>

    {page.links.length > 0 && (
      <section class="space-y-3">
        <h2 class="font-semibold font-serif text-xl tracking-tight">
          {t.entry.links}
        </h2>
        <div class="flex flex-wrap gap-4 text-sm">
          {page.links.map((link) => (
            <a
              class="text-muted-foreground underline transition-colors hover:text-foreground"
              href={link.href}
              rel="noopener noreferrer"
              target="_blank"
            >
              {link.label}
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</Layout>
