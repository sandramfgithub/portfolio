---
import { getProjectsPageViewModel } from '@/application/portfolio/queries';
import CaseStudyList from '@/components/portfolio/entries/case-study-list.astro';
import ProjectGrid from '@/components/portfolio/entries/project-grid.astro';
import type { Lang } from '@/i18n/translations';
import { getTranslations } from '@/i18n/utils';
import Layout from '@/layouts/main.astro';

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = getTranslations(lang);
const page = await getProjectsPageViewModel(lang);
---

<Layout description={page.description} lang={lang} title={page.title}>
  <section class="py-2 sm:py-4">
    {page.introParagraphs.map((paragraph) => (
      <p
        class="mx-auto max-w-2xl text-center text-muted-foreground text-sm leading-6 sm:text-base sm:leading-7"
      >
        {paragraph}
      </p>
    ))}
  </section>

  <section aria-labelledby="public-heading" class="space-y-5">
    <h2
      id="public-heading"
      class="font-serif text-xl font-semibold tracking-tight"
    >
      {t.projects.publicHeading}
    </h2>
    <ProjectGrid projects={page.publicProjects} lang={lang} />
  </section>

  <section aria-labelledby="cases-heading" class="space-y-5">
    <h2
      id="cases-heading"
      class="font-serif text-xl font-semibold tracking-tight"
    >
      {t.projects.caseStudiesHeading}
    </h2>
    <CaseStudyList cases={page.caseStudies} lang={lang} />
  </section>
</Layout>
