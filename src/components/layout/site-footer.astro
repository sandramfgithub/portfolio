---
import FooterCat from '@/components/layout/footer-cat.astro';
import type { Lang } from '@/i18n/translations';
import { getTranslations } from '@/i18n/utils';

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = getTranslations(lang);
const year = new Date().getFullYear();
---

<div class="relative mt-6 h-[clamp(6rem,15.5vw,10.75rem)] select-none">
  <FooterCat />
</div>
<footer class="border-t border-border/50 py-8" transition:animate="none">
  <div
    class="flex flex-col gap-2 text-sm text-muted-foreground sm:flex-row sm:items-center sm:justify-between"
  >
    <p>{t.footer.madeWith} ♥ {t.footer.tools}</p>
    <p class="text-xs tracking-[0.14em] uppercase">
      © {year} Sandra Martínez Fernández
    </p>
  </div>
</footer>
