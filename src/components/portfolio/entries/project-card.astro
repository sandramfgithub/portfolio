---
import { createAnalyticsAttributes } from '@/application/analytics/attributes';
import type { ProjectCardViewModel } from '@/application/portfolio/dto';
import { StackList } from '@/components/portfolio/skills/stack-list';
import { Badge } from '@/components/ui/badge';
import type { Lang } from '@/i18n/translations';
import { getTranslations } from '@/i18n/utils';

type Props = ProjectCardViewModel & {
  animationDelay?: number;
  lang: Lang;
};

const {
  slug,
  href,
  title,
  summary,
  skills,
  github,
  publicationState,
  lang,
  animationDelay = 0,
} = Astro.props as Props;

const t = getTranslations(lang);
const isComingSoon = publicationState === 'coming-soon';
---

<div
  class:list={[
    'group fade-up-item flex flex-col gap-3 rounded-lg border border-border/60 bg-card p-4',
    !isComingSoon && 'card-lift',
    isComingSoon && 'opacity-85',
  ]}
  style={`animation-delay: ${animationDelay}ms`}
>
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-2">
      {isComingSoon && (
        <Badge className="text-[11px]" variant="outline">
          {t.projects.comingSoon}
        </Badge>
      )}
      <h3 class="font-semibold text-base">
        {href ? (
          <a
            {...createAnalyticsAttributes('project_detail_clicked', {
              lang,
              location: 'projects',
              publicationState,
              slug,
            })}
            class="transition-colors hover:text-muted-foreground"
            href={href}
          >
            {title}
          </a>
        ) : (
          <span>{title}</span>
        )}
      </h3>
    </div>
    {github && (
      <a
        {...createAnalyticsAttributes('project_repository_clicked', {
          lang,
          location: 'projects',
          publicationState,
          slug,
        })}
        class="text-muted-foreground text-sm underline transition-colors hover:text-foreground group-hover:text-foreground"
        href={github}
        rel="noopener noreferrer"
        target="_blank"
      >
        GitHub
      </a>
    )}
  </div>
  <p
    class:list={[
      'text-muted-foreground text-sm leading-6',
      isComingSoon && 'pointer-events-none select-none blur-[3px]',
    ]}
  >
    {summary}
  </p>
  <div
    class:list={[
      'mt-auto',
      isComingSoon && 'pointer-events-none select-none blur-[3px]',
    ]}
  >
    <StackList client:visible lang={lang} location="projects" skills={skills} />
  </div>
</div>
