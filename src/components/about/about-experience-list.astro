---
import type { AboutExperienceViewModel } from '@/application/portfolio/dto';
import { StackList } from '@/components/portfolio/skills/stack-list';
import { Separator } from '@/components/ui/separator';
import type { Lang } from '@/i18n/translations';

type Props = {
  experience: readonly AboutExperienceViewModel[];
  heading: string;
  lang: Lang;
};

const { experience, heading, lang } = Astro.props;
---

<section aria-labelledby="exp-heading" class="space-y-5">
  <h2 id="exp-heading" class="font-serif text-xl font-semibold tracking-tight">
    {heading}
  </h2>
  {experience.map((item, index) => (
    <div>
      {index > 0 && <Separator className="mb-5" />}
      <div class="flex flex-col gap-1 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h3 class="font-semibold text-sm">{item.role}</h3>
          <p class="text-muted-foreground text-sm">{item.company}</p>
        </div>
        <span class="text-muted-foreground text-sm">{item.period}</span>
      </div>
      <p class="mt-3 text-muted-foreground text-sm leading-7">
        {item.summary}
      </p>
      <ul class="mt-3 grid gap-1.5 text-muted-foreground text-sm leading-7">
        {item.achievements.map((achievement) => (
          <li class="flex gap-3">
            <span class="mt-[0.6rem] h-1.5 w-1.5 shrink-0 rounded-full bg-foreground/30" />
            <span>{achievement}</span>
          </li>
        ))}
      </ul>
      <div class="mt-3">
        <StackList
          lang={lang}
          location="about"
          skills={item.skills}
          client:visible
        />
      </div>
    </div>
  ))}
</section>
